{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/digibeing1001/fde-agent-team/config/feishu-team.schema.json",
  "title": "Feishu project-scoped agent team",
  "type": "object",
  "required": ["schema_version", "team_id", "project_id", "chat_id_env", "secretary_agent_id", "agents"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "team_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1},
    "chat_name": {"type": "string", "minLength": 1, "maxLength": 60},
    "description": {"type": "string", "maxLength": 100},
    "chat_id_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
    "secretary_agent_id": {"type": "string", "minLength": 1},
    "policy": {
      "type": "object",
      "properties": {"max_hops": {"type": "integer", "minimum": 1, "maximum": 12}},
      "additionalProperties": true
    },
    "agents": {
      "type": "array", "minItems": 1, "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["agent_id", "profile", "app_id_env", "open_id_env"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "display_name": {"type": "string", "minLength": 1, "maxLength": 40},
          "profile": {"type": "string", "minLength": 1},
          "app_id_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
          "open_id_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
